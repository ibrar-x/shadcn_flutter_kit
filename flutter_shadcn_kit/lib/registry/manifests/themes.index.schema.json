{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flutter-shadcn.github.io/registry-directory/registry/themes.index.schema.v1.json",
  "title": "Registry Theme Artifact Manifest Schema",
  "description": "Declarative manifest for generated theme install artifacts published by a registry.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "themes"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "themes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/themeManifestEntry"
      }
    }
  },
  "$defs": {
    "themeManifestEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "label",
        "files"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_\\-]{1,63}$",
          "description": "Stable theme identifier used by the CLI."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "description": "Human-readable theme name."
        },
        "description": {
          "type": "string",
          "maxLength": 500
        },
        "source": {
          "$ref": "#/$defs/safeRelativePathOrHttpsUrl",
          "description": "Optional source theme document for inspection or documentation."
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/themeManifestFile"
          }
        }
      }
    },
    "themeManifestFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "target",
        "sha256"
      ],
      "properties": {
        "source": {
          "$ref": "#/$defs/safeRelativePathOrHttpsUrl",
          "description": "Generated artifact source path in the registry, or an absolute HTTPS URL."
        },
        "target": {
          "$ref": "#/$defs/safeProjectRelativePath",
          "description": "Destination path relative to the consumer project root."
        },
        "sha256": {
          "$ref": "#/$defs/sha256Hex64"
        }
      }
    },
    "safeRelativePathOrHttpsUrl": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "anyOf": [
        {
          "pattern": "^(?!/)(?!.*\\s)(?!.*\\.\\./)(?!.*\\./\\./)[-a-zA-Z0-9_./]+$"
        },
        {
          "pattern": "^https://[^\\s]+$"
        }
      ]
    },
    "safeProjectRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": "^(?!/)(?!.*\\\\)(?!.*\\s)(?!.*\\.\\./)(?!.*\\./\\./)[-a-zA-Z0-9_./]+$"
    },
    "sha256Hex64": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
